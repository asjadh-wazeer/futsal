# Database
DATABASE_URL="postgresql://user:password@localhost:5432/futsal_db?schema=public"

# JWT
JWT_SECRET="replace-with-a-long-random-secret"
JWT_EXPIRES_IN="7d"

# Server
PORT=3001
FRONTEND_URL="http://localhost:5173"

# Google OAuth (Customer "Sign in with Google")
# Create credentials at https://console.cloud.google.com/apis/credentials
# Authorized redirect URI must match GOOGLE_CALLBACK_URL exactly.
GOOGLE_CLIENT_ID="your-google-client-id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="your-google-client-secret"
GOOGLE_CALLBACK_URL="http://localhost:3001/api/customer-auth/google/callback"

# Payment gateway — PayHere (https://www.payhere.lk)
PAYHERE_MERCHANT_ID=""
PAYHERE_MERCHANT_SECRET=""
PAYHERE_MODE="sandbox"
BACKEND_URL="http://localhost:3001"

# SMS / Email notifications
SMS_API_KEY=""
SMS_SENDER_ID=""
SMTP_HOST=""
SMTP_PORT=587
SMTP_USER=""
SMTP_PASSWORD=""
NOTIFICATION_FROM_EMAIL="bookings@lankafutsal.lk"
